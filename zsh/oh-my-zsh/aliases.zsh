alias ls=lsd
alias nv=nvim
alias lg=lazygit
alias man='MANPAGER="nvim +Man!" man'
alias fastfetch='clear; fastfetch'
alias mucli='music-cli'
alias lserv='live-server --browser=brave-browser'

# Starting a postgres server
alias pgstart='sudo systemctl start postgresql'
alias pgstop='sudo systemctl stop postgresql'

# Starting a mariadb server
alias mdbstart='sudo systemctl start mariadb'
alias mdbstop='sudo systemctl stop mariadb'
